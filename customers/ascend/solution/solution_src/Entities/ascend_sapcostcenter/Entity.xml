      <LocalizedCollectionNames><LocalizedCollectionName description="SAP Cost Centers (Demo)" languagecode="1033" /></LocalizedCollectionNames>
      <Descriptions><Description description="Emulates SAP ECC 6.0 CSKS (cost center master data). DEMO DATA ONLY." languagecode="1033" /></Descriptions>
      <attributes>
        <attribute PhysicalName="ascend_sapcostcenterid"><Type>primarykey</Type><Name>ascend_sapcostcenterid</Name><LogicalName>ascend_sapcostcenterid</LogicalName></attribute>
