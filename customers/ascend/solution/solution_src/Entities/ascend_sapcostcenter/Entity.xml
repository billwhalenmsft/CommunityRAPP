<!-- ascend_sapcostcenter — Emulates SAP CSKS (Cost Center Master) -->
<Entity>
  <Name LocalizedName="SAP Cost Center (Demo)" OriginalName="ascend_sapcostcenter">ascend_sapcostcenter</Name>
  <EntityInfo>
    <entity Name="ascend_sapcostcenter">
