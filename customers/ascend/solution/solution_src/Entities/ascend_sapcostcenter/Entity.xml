        <attribute PhysicalName="ascend_datbi"><Type>datetime</Type><Name>ascend_datbi</Name><LocalizedNames><LocalizedName description="Valid To (DATBI)" languagecode="1033" /></LocalizedNames></attribute>
        <!-- Description -->
        <attribute PhysicalName="ascend_ktext"><Type>nvarchar</Type><Name>ascend_ktext</Name><MaxLength>40</MaxLength><LocalizedNames><LocalizedName description="Description (KTEXT)" languagecode="1033" /></LocalizedNames></attribute>
        <!-- Active flag -->
        <attribute PhysicalName="ascend_active"><Type>bit</Type><Name>ascend_active</Name><LocalizedNames><LocalizedName description="Active" languagecode="1033" /></LocalizedNames><DefaultValue>1</DefaultValue></attribute>
