        <attribute PhysicalName="ascend_kostl"><Type>nvarchar</Type><Name>ascend_kostl</Name><MaxLength>10</MaxLength><LocalizedNames><LocalizedName description="Cost Center (KOSTL)" languagecode="1033" /></LocalizedNames><RequiredLevel>required</RequiredLevel></attribute>
