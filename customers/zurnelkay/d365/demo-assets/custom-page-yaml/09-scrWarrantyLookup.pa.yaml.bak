# ============================================
#  WARRANTY LOOKUP (scrWarrantyLookup)
#  Format: Power Apps pa.yaml SchemaV3
# ============================================
#
#  Search for a product by serial number using
#  the Product Serials table (cr74e_productserial)
#  from the Warranty and Claim Operations solution.
#  Shows warranty status (Active / Expired) and
#  allows the agent to file a Warranty Claim.
#
#  Prerequisites (data sources to add):
#    - 'Product Serials'   (cr74e_productserial)
#    - 'Warranty Claims'   (cr74e_warrantyclaim)
#
#  Variables initialized in scrHome.OnVisible:
#    varSerialSearched  - boolean (false)
#    varClaimSubmitted  - boolean (false)
#    varClaimError      - string ("")
#    varClaimNumber     - string ("")
#    varPassedSerial    - string ("")  ← parsed from JS loader
#
#  Column name notes (cr74e_productserial):
#    - 'Serial ID'            cr74e_serialnumber    (String)
#    - 'Product Name'         cr74e_productname     (String)
#    - 'Warranty Start'       cr74e_warrantystart   (DateTime)
#    - 'Warranty End'         cr74e_warrantyend     (DateTime)
#    - 'Original Order Number' cr74e_originalordernumber (String)
#    - 'Warranty'             cr74e_warranty        (Lookup → msdyn_warranty)
#
#  Column name notes (cr74e_warrantyclaim):
#    - 'Product Serial'       cr74e_productserial   (Lookup)
#    - 'Description'          cr74e_description     (Memo)
#    - 'Claim Date'           cr74e_claimdate       (DateTime)
# ============================================

Screens:
  scrWarrantyLookup:
    Properties:
      Fill: =RGBA(250, 250, 250, 1)
      OnVisible: |-
        =Set(varSerialSearched, false);
        Set(varClaimSubmitted, false);
        Set(varClaimError, "");
        Set(varClaimNumber, "");
        Clear(colSerialResult);
        // Parse serial (4th pipe segment) from JS loader param
        Set(
            varPassedSerial,
            With(
                { raw: Param("recordId") },
                If(
                    CountRows(Split(raw, "|")) >= 4,
                    Last(FirstN(Split(raw, "|"), 4)).Value,
                    ""
                )
            )
        );
        // Auto-search if serial was passed from case form
        If(
            !IsBlank(varPassedSerial),
            ClearCollect(
                colSerialResult,
                Filter('Product Serials', 'Serial ID' = varPassedSerial)
            );
            Set(varSerialSearched, true)
        )
    Children:
      # -- Blue accent bar --
      - rectWarrBar:
          Control: Rectangle
          Properties:
            X: =0
            Y: =0
            Width: =Parent.Width
            Height: =6
            Fill: =RGBA(0, 78, 140, 1)

      # -- Warranty icon --
      - icoWarrIcon:
          Control: Classic/Icon
          Properties:
            Icon: =Icon.Lock
            X: =16
            Y: =18
            Width: =32
            Height: =32
            Color: =RGBA(0, 78, 140, 1)

      # -- Title --
      - lblWarrTitle:
          Control: Label
          Properties:
            Text: ="Warranty Lookup"
            X: =58
            Y: =16
            Width: =220
            Height: =30
            Size: =20
            FontWeight: =FontWeight.Bold
            Color: =RGBA(50, 49, 48, 1)

      # -- Home button (top right) --
      - btnWarrHome:
          Control: Classic/Icon
          Properties:
            Icon: =Icon.Home
            X: =Parent.Width - 52
            Y: =16
            Width: =32
            Height: =32
            Color: =RGBA(96, 94, 92, 1)
            OnSelect: =Navigate(scrHome, ScreenTransition.None)

      # -- Subtitle --
      - lblWarrSubtitle:
          Control: Label
          Properties:
            Text: ="Search by serial number"
            X: =58
            Y: =48
            Width: =Parent.Width - 74
            Height: =22
            Size: =11
            Color: =RGBA(96, 94, 92, 1)

      # -- Divider --
      - rectWarrDivider1:
          Control: Rectangle
          Properties:
            X: =16
            Y: =78
            Width: =Parent.Width - 32
            Height: =1
            Fill: =RGBA(237, 235, 233, 1)

      # =============================================
      #  SEARCH SECTION
      # =============================================

      - lblSerialLbl:
          Control: Label
          Properties:
            Text: ="Serial Number"
            X: =16
            Y: =88
            Width: =Parent.Width - 32
            Height: =18
            Size: =11
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(50, 49, 48, 1)

      - txtSerialNum:
          Control: Classic/TextInput
          Properties:
            Default: =varPassedSerial
            HintText: ="Enter serial number..."
            X: =16
            Y: =110
            Width: =Parent.Width - 32
            Height: =36
            BorderColor: =RGBA(200, 198, 196, 1)
            FocusedBorderColor: =RGBA(0, 78, 140, 1)
            Size: =12

      - btnSerialSearch:
          Control: Classic/Button
          Properties:
            Text: ="Search"
            X: =16
            Y: =154
            Width: =Parent.Width - 32
            Height: =36
            Fill: =RGBA(0, 78, 140, 1)
            Color: =RGBA(255, 255, 255, 1)
            Size: =12
            FontWeight: =FontWeight.Bold
            BorderThickness: =0
            HoverFill: =RGBA(0, 58, 120, 1)
            PressedFill: =RGBA(0, 38, 100, 1)
            DisabledFill: =RGBA(200, 198, 196, 1)
            DisplayMode: |-
              =If(Trim(txtSerialNum.Text) = "", DisplayMode.Disabled, DisplayMode.Edit)
            OnSelect: |-
              =Set(varClaimSubmitted, false);
              Set(varClaimError, "");
              Set(varClaimNumber, "");
              ClearCollect(
                  colSerialResult,
                  Filter('Product Serials', 'Serial ID' = Trim(txtSerialNum.Text))
              );
              Set(varSerialSearched, true)

      # -- Divider after search --
      - rectWarrDivider2:
          Control: Rectangle
          Properties:
            X: =16
            Y: =198
            Width: =Parent.Width - 32
            Height: =1
            Fill: =RGBA(237, 235, 233, 1)
            Visible: =varSerialSearched

      # =============================================
      #  NOT FOUND STATE
      # =============================================

      - lblNotFound:
          Control: Label
          Properties:
            Text: |-
              ="No serial number found matching '" & Trim(txtSerialNum.Text) & "'."
            X: =16
            Y: =210
            Width: =Parent.Width - 32
            Height: =40
            Size: =11
            Color: =RGBA(97, 96, 96, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) = 0

      # =============================================
      #  RESULT CARD
      # =============================================

      - rectResultCard:
          Control: Rectangle
          Properties:
            X: =16
            Y: =206
            Width: =Parent.Width - 32
            Height: =180
            Fill: =RGBA(255, 255, 255, 1)
            BorderColor: =RGBA(237, 235, 233, 1)
            BorderThickness: =1
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      # -- Product Name row --
      - lblResProdLbl:
          Control: Label
          Properties:
            Text: ="Product"
            X: =24
            Y: =214
            Width: =100
            Height: =20
            Size: =11
            Color: =RGBA(96, 94, 92, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      - lblResProdVal:
          Control: Label
          Properties:
            Text: =First(colSerialResult).'Product Name'
            X: =128
            Y: =214
            Width: =Parent.Width - 148
            Height: =20
            Size: =11
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(50, 49, 48, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      # -- Serial ID row --
      - lblResSerialLbl:
          Control: Label
          Properties:
            Text: ="Serial ID"
            X: =24
            Y: =238
            Width: =100
            Height: =20
            Size: =11
            Color: =RGBA(96, 94, 92, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      - lblResSerialVal:
          Control: Label
          Properties:
            Text: =First(colSerialResult).'Serial ID'
            X: =128
            Y: =238
            Width: =Parent.Width - 148
            Height: =20
            Size: =11
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(50, 49, 48, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      # -- Original Order row --
      - lblResOrderLbl:
          Control: Label
          Properties:
            Text: |-
              ="Orig. Order #"
            X: =24
            Y: =262
            Width: =100
            Height: =20
            Size: =11
            Color: =RGBA(96, 94, 92, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      - lblResOrderVal:
          Control: Label
          Properties:
            Text: |-
              =If(
                  IsBlank(First(colSerialResult).'Original Order Number'),
                  "—",
                  First(colSerialResult).'Original Order Number'
              )
            X: =128
            Y: =262
            Width: =Parent.Width - 148
            Height: =20
            Size: =11
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(50, 49, 48, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      # -- Warranty Start row --
      - lblResWStartLbl:
          Control: Label
          Properties:
            Text: ="Warr. Start"
            X: =24
            Y: =286
            Width: =100
            Height: =20
            Size: =11
            Color: =RGBA(96, 94, 92, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      - lblResWStartVal:
          Control: Label
          Properties:
            Text: |-
              =If(
                  IsBlank(First(colSerialResult).'Warranty Start'),
                  "—",
                  Text(First(colSerialResult).'Warranty Start', "mm/dd/yyyy")
              )
            X: =128
            Y: =286
            Width: =Parent.Width - 148
            Height: =20
            Size: =11
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(50, 49, 48, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      # -- Warranty End row --
      - lblResWEndLbl:
          Control: Label
          Properties:
            Text: ="Warr. End"
            X: =24
            Y: =310
            Width: =100
            Height: =20
            Size: =11
            Color: =RGBA(96, 94, 92, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      - lblResWEndVal:
          Control: Label
          Properties:
            Text: |-
              =If(
                  IsBlank(First(colSerialResult).'Warranty End'),
                  "—",
                  Text(First(colSerialResult).'Warranty End', "mm/dd/yyyy")
              )
            X: =128
            Y: =310
            Width: =150
            Height: =20
            Size: =11
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(50, 49, 48, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      # -- Warranty Status badge --
      - lblWarrStatus:
          Control: Label
          Properties:
            Text: |-
              =If(
                  IsBlank(First(colSerialResult).'Warranty End'),
                  "NO WARRANTY",
                  If(
                      DateDiff(Today(), First(colSerialResult).'Warranty End', TimeUnit.Days) > 0,
                      "ACTIVE",
                      "EXPIRED"
                  )
              )
            X: =Parent.Width - 102
            Y: =308
            Width: =80
            Height: =24
            Size: =10
            FontWeight: =FontWeight.Bold
            Align: =Align.Center
            Color: |-
              =If(
                  IsBlank(First(colSerialResult).'Warranty End'),
                  RGBA(97, 96, 96, 1),
                  If(
                      DateDiff(Today(), First(colSerialResult).'Warranty End', TimeUnit.Days) > 0,
                      RGBA(16, 124, 16, 1),
                      RGBA(197, 54, 1, 1)
                  )
              )
            Fill: |-
              =If(
                  IsBlank(First(colSerialResult).'Warranty End'),
                  RGBA(237, 235, 233, 1),
                  If(
                      DateDiff(Today(), First(colSerialResult).'Warranty End', TimeUnit.Days) > 0,
                      RGBA(223, 246, 221, 1),
                      RGBA(253, 231, 233, 1)
                  )
              )
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      # =============================================
      #  FILE WARRANTY CLAIM SECTION
      # Visible only when: result found + not yet submitted
      # =============================================

      - rectClaimDivider:
          Control: Rectangle
          Properties:
            X: =16
            Y: =396
            Width: =Parent.Width - 32
            Height: =1
            Fill: =RGBA(237, 235, 233, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0

      - lblClaimSection:
          Control: Label
          Properties:
            Text: ="File a Warranty Claim"
            X: =16
            Y: =404
            Width: =Parent.Width - 32
            Height: =22
            Size: =12
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(0, 78, 140, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0 && !varClaimSubmitted

      - lblClaimDescLbl:
          Control: Label
          Properties:
            Text: ="Claim Description"
            X: =16
            Y: =430
            Width: =Parent.Width - 32
            Height: =18
            Size: =11
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(50, 49, 48, 1)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0 && !varClaimSubmitted

      - txtClaimDesc:
          Control: Classic/TextInput
          Properties:
            HintText: ="Describe the issue or claim..."
            X: =16
            Y: =452
            Width: =Parent.Width - 32
            Height: =70
            Mode: =TextMode.MultiLine
            BorderColor: =RGBA(200, 198, 196, 1)
            FocusedBorderColor: =RGBA(0, 78, 140, 1)
            Size: =11
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0 && !varClaimSubmitted

      # -- Submit Claim button --
      # Uses LookUp for 'Product Serial' to return typed DataEntity
      - btnSubmitClaim:
          Control: Classic/Button
          Properties:
            Text: ="Submit Warranty Claim"
            X: =16
            Y: =530
            Width: =Parent.Width - 32
            Height: =38
            Fill: =RGBA(0, 78, 140, 1)
            Color: =RGBA(255, 255, 255, 1)
            Size: =12
            FontWeight: =FontWeight.Bold
            BorderThickness: =0
            HoverFill: =RGBA(0, 58, 120, 1)
            PressedFill: =RGBA(0, 38, 100, 1)
            DisabledFill: =RGBA(200, 198, 196, 1)
            DisplayMode: |-
              =If(Trim(txtClaimDesc.Text) = "", DisplayMode.Disabled, DisplayMode.Edit)
            Visible: |-
              =varSerialSearched && CountRows(colSerialResult) > 0 && !varClaimSubmitted
            OnSelect: |-
              =Set(varClaimError, "");
              Set(varClaimSubmitted, false);
              IfError(
                  Patch(
                      'Warranty Claims',
                      Blank(),
                      {
                          'Product Serial': LookUp('Product Serials', 'Serial ID' = First(colSerialResult).'Serial ID'),
                          Description: txtClaimDesc.Text,
                          'Claim Date': Now()
                      }
                  );
                  Set(varClaimSubmitted, true),
                  Set(varClaimError, "Error filing claim: " & FirstError.Message)
              )

      # -- Claim Error --
      - lblClaimError:
          Control: Label
          Properties:
            Text: =varClaimError
            X: =16
            Y: =576
            Width: =Parent.Width - 32
            Height: =40
            Size: =11
            Color: =RGBA(197, 54, 1, 1)
            Visible: =varClaimError <> ""

      # -- Claim Success --
      - lblClaimSuccess:
          Control: Label
          Properties:
            Text: |-
              ="✓ Warranty claim submitted successfully"
            X: =16
            Y: =404
            Width: =Parent.Width - 32
            Height: =24
            Size: =12
            FontWeight: =FontWeight.Semibold
            Color: =RGBA(16, 124, 16, 1)
            Visible: =varClaimSubmitted

      # =============================================
      #  FOOTER
      # =============================================

      # -- Back to Service Toolkit --
      - btnWarrBackHome:
          Control: Classic/Button
          Properties:
            Text: ="Back to Service Toolkit"
            X: =16
            Y: =Parent.Height - 50
            Width: =Parent.Width - 32
            Height: =38
            Fill: =RGBA(255, 255, 255, 1)
            Color: =RGBA(0, 78, 140, 1)
            BorderColor: =RGBA(0, 78, 140, 1)
            BorderThickness: =1
            Size: =12
            HoverFill: =RGBA(0, 78, 140, 0.05)
            PressedFill: =RGBA(0, 78, 140, 0.1)
            OnSelect: =Navigate(scrHome, ScreenTransition.None)
