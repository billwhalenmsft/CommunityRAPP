{
  "name": "flow_analyze_competitor",
  "displayName": "Analyze Competitor Flow",
  "description": "Power Automate flow for analyze_competitor",
  "trigger": {
    "kind": "PowerVirtualAgents",
    "inputs": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string"
        },
        "parameters": {
          "type": "object"
        }
      }
    }
  },
  "actions": [
    {
      "kind": "Dataverse_ListRows",
      "connection": "dataverse_connection",
      "inputs": {
        "entityName": "rapp_data"
      },
      "outputs": {
        "rows": "dataverseRows"
      }
    },
    {
      "kind": "AzureOpenAI_ChatCompletion",
      "connection": "azure_openai_connection",
      "inputs": {
        "prompt": "Process the data for analyze_competitor",
        "systemMessage": "Commercial Brass Competitive Intelligence Agent for Zurn Elkay.\n\nMonitors Commercial Faucets, Flush Valves, and Electronic/Touchless fixtures.\nSpecial focus on platform launches, IoT, and water management systems."
      },
      "outputs": {
        "response": "aiResponse"
      }
    },
    {
      "kind": "Response",
      "inputs": {
        "result": "@{variables('aiResponse') ?? 'Action completed successfully'}"
      }
    }
  ],
  "outputs": {
    "result": {
      "type": "string",
      "description": "Result of the action"
    }
  }
}