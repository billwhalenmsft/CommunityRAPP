{
  "name": "flow_run_quarterly_analysis",
  "displayName": "Run Quarterly Analysis Flow",
  "description": "Power Automate flow for run_quarterly_analysis",
  "trigger": {
    "kind": "PowerVirtualAgents",
    "inputs": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string"
        },
        "parameters": {
          "type": "object"
        }
      }
    }
  },
  "actions": [
    {
      "kind": "Dataverse_ListRows",
      "connection": "dataverse_connection",
      "inputs": {
        "entityName": "rapp_data"
      },
      "outputs": {
        "rows": "dataverseRows"
      }
    },
    {
      "kind": "AzureOpenAI_ChatCompletion",
      "connection": "azure_openai_connection",
      "inputs": {
        "prompt": "Process the data for run_quarterly_analysis",
        "systemMessage": "Sinks Competitive Intelligence Agent for Zurn Elkay.\n\nMonitors Commercial Sinks, Healthcare/Patient Care, and Food Service.\nSpecial focus on healthcare infection control and ADA compliance."
      },
      "outputs": {
        "response": "aiResponse"
      }
    },
    {
      "kind": "Response",
      "inputs": {
        "result": "@{variables('aiResponse') ?? 'Action completed successfully'}"
      }
    }
  ],
  "outputs": {
    "result": {
      "type": "string",
      "description": "Result of the action"
    }
  }
}