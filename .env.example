# Copy this file to local.settings.json and fill in your values.
# NEVER commit local.settings.json — it is gitignored.
#
# For Azure Functions local dev, the actual format is JSON (see local.settings.template.json).
# This .env.example lists all required environment variables for reference.

# ── Azure OpenAI ────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Azure Storage (required for agent memory + file shares) ─────────────────
AzureWebJobsStorage=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name

# ── Storage mode ────────────────────────────────────────────────────────────
# Set to "true" to use Azure File Storage (default for production + GitHub Actions)
# Set to "false" to use local .local_storage/ folder for offline dev
USE_CLOUD_STORAGE=true

# ── Azure Functions runtime ──────────────────────────────────────────────────
FUNCTIONS_WORKER_RUNTIME=python

# ── Assistant personality ────────────────────────────────────────────────────
ASSISTANT_NAME=Copilot Entra Agent
CHARACTERISTIC_DESCRIPTION=A helpful enterprise AI assistant for Discrete Manufacturing

# ── CoE GitHub Actions (set as GitHub secrets, not local) ───────────────────
# COE_REPO=billwhalenmsft/CommunityRAPP-BillWhalen
# GITHUB_TOKEN=ghp_...   (auto-provided by GitHub Actions)

# ── D365 integration (optional — needed for D365 inventory agent) ────────────
# D365_CLIENT_ID=your-entra-app-client-id
# D365_CLIENT_SECRET=your-entra-app-client-secret
# D365_MASTER_CE_MFG_URL=https://orgecbce8ef.crm.dynamics.com/
# D365_MFG_GOLD_TEMPLATE_URL=https://org6feab6b5.crm.dynamics.com/
